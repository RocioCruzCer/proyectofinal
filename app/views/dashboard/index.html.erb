<div class="dashboard-wrapper">
  
  <!-- Fondo animado -->
  <div class="animated-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="particles-container">
      <% 12.times do |i| %><div class="particle"></div><% end %>
    </div>
    <div class="wave-bg"></div>
  </div>
  
  <div class="dashboard-container">
    
    <!-- Tarjeta de perfil -->
    <div class="profile-card animate-card">
      <div class="card-glow"></div>
      <div class="profile-header">
        <div class="profile-avatar">
          <% if usuario_actual.respond_to?(:foto_perfil) && usuario_actual.foto_perfil.present? %>
            <%= image_tag usuario_actual.foto_perfil, class: "avatar-image" %>
          <% else %>
            <div class="avatar-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"/></svg>
            </div>
          <% end %>
          <div class="avatar-ring"></div>
        </div>
        <div class="profile-title">
          <h2>Perfil de Usuario</h2>
          <p>Datos de acceso y credenciales</p>
        </div>
      </div>

      <div class="profile-info">
        <% info_items = [
          { icon: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z', label: 'Nombre completo', value: usuario_actual.strNombreUsuario },
          { icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6L12 13 2 6', label: 'Correo electrónico', value: usuario_actual.strCorreo },
          { icon: 'M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83 M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z', label: 'Perfil asignado', value: (usuario_actual.respond_to?(:perfil) && usuario_actual.perfil ? usuario_actual.perfil.strNombrePerfil : "Administrador") },
          { icon: 'M12 8v4l3 3M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z', label: 'Estado de la cuenta', value: '<span class="status-badge"><span class="status-dot"></span>Activo</span>' }
        ] %>
        <% info_items.each_with_index do |item, idx| %>
          <div class="info-row" style="animation-delay: <%= 0.1 * (idx + 1) %>s">
            <div class="info-label"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="<%= item[:icon] %>"/></svg><span><%= item[:label] %></span></div>
            <div class="info-value"><%= raw item[:value] %></div>
          </div>
        <% end %>
      </div>

      <div class="profile-footer">
        <div class="access-info"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><span>Acceso autorizado al sistema corporativo</span></div>
      </div>
    </div>

    <!-- Tarjeta de bienvenida -->
    <div class="welcome-card animate-card">
      <div class="card-border-animation"></div>
      <div class="welcome-content">
        <div class="welcome-badge"><span class="badge-text">Panel de Control</span></div>
        <h1 class="welcome-title">Bienvenido, <span class="user-name-highlight"><%= usuario_actual.strNombreUsuario.split(' ').first %></span></h1>
        <p class="welcome-description">Le damos la bienvenida al Sistema de Gestión Corporativa. Desde este panel central podrá administrar y supervisar todas las operaciones del negocio con total seguridad y eficiencia.</p>
        <div class="welcome-features">
          <div class="feature-item"><div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><span>Acceso seguro</span></div>
          <div class="feature-item"><div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><span>Protección de datos</span></div>
          <div class="feature-item"><div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div><span>Notificaciones en tiempo real</span></div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  :root {
    --primary: #246BD1;
    --secondary: #7C8EF8;
    --accent: #F3B0B8;
    --success: #02900E;
    --gray-light: #F8F9FC;
    --gray-medium: #6C757D;
    --gray-dark: #2C3E50;
    --white: #FFFFFF;
    --border: #E9ECEF;
  }

  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

  /* Fondo animado */
  .dashboard-wrapper { position: relative; min-height: calc(100vh - 140px); overflow-x: hidden; }
  .animated-bg { position: fixed; inset: 0; z-index: 0; background: linear-gradient(135deg, #F5F7FA 0%, #E9EEF3 100%); overflow: hidden; }
  .gradient-orb { position: absolute; border-radius: 50%; filter: blur(60px); opacity: 0.5; animation: floatOrb 20s ease-in-out infinite; }
  .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(36,107,209,0.3) 0%, rgba(124,142,248,0.1) 100%); top: -200px; left: -200px; }
  .orb-2 { width: 600px; height: 600px; background: radial-gradient(circle, rgba(124,142,248,0.25) 0%, rgba(243,176,184,0.1) 100%); bottom: -250px; right: -200px; animation-delay: -5s; }
  .orb-3 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(2,144,14,0.2) 0%, rgba(149,191,161,0.1) 100%); top: 50%; left: 50%; transform: translate(-50%, -50%); animation-delay: -10s; }
  @keyframes floatOrb { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(30px,-30px) scale(1.1); } 66% { transform: translate(-20px,20px) scale(0.95); } }
  
  .particles-container { position: absolute; width: 100%; height: 100%; overflow: hidden; }
  .particle { position: absolute; width: 3px; height: 3px; background: var(--primary); border-radius: 50%; opacity: 0.4; animation: particleDrift 15s linear infinite; }
  .particle:nth-child(1) { left: 10%; top: 20%; animation-duration: 12s; width: 4px; }
  .particle:nth-child(2) { left: 20%; top: 70%; animation-duration: 18s; animation-delay: 2s; width: 2px; background: var(--secondary); }
  .particle:nth-child(3) { left: 40%; top: 30%; animation-duration: 14s; animation-delay: 1s; }
  .particle:nth-child(4) { left: 60%; top: 80%; animation-duration: 20s; animation-delay: 3s; width: 5px; background: var(--accent); }
  .particle:nth-child(5) { left: 75%; top: 15%; animation-duration: 16s; animation-delay: 0.5s; }
  .particle:nth-child(6) { left: 85%; top: 50%; animation-duration: 22s; animation-delay: 1.5s; width: 4px; background: var(--success); }
  .particle:nth-child(7) { left: 15%; top: 45%; animation-duration: 13s; animation-delay: 2.5s; width: 2px; }
  .particle:nth-child(8) { left: 50%; top: 85%; animation-duration: 19s; animation-delay: 0.8s; background: var(--secondary); }
  .particle:nth-child(9) { left: 30%; top: 10%; animation-duration: 17s; animation-delay: 1.2s; width: 4px; }
  .particle:nth-child(10) { left: 70%; top: 60%; animation-duration: 15s; animation-delay: 2s; background: var(--accent); }
  @keyframes particleDrift { 0% { transform: translateY(0) translateX(0); opacity: 0; } 10% { opacity: 0.4; } 90% { opacity: 0.4; } 100% { transform: translateY(-100vh) translateX(50px); opacity: 0; } }
  
  .wave-bg { position: absolute; bottom: 0; left: 0; width: 100%; height: 200px; background: linear-gradient(180deg, transparent, rgba(36,107,209,0.03)); pointer-events: none; }
  .wave-bg::before, .wave-bg::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 100px; background: repeating-linear-gradient(90deg, transparent, transparent 50px, rgba(36,107,209,0.05) 50px, rgba(124,142,248,0.05) 100px); animation: waveMove 20s linear infinite; }
  .wave-bg::after { opacity: 0.5; animation-direction: reverse; animation-duration: 15s; }
  @keyframes waveMove { 0% { transform: translateX(0); } 100% { transform: translateX(100px); } }

  /* Contenedor principal */
  .dashboard-container { position: relative; z-index: 1; max-width: 1300px; margin: 0 auto; padding: 40px 32px; display: grid; grid-template-columns: 440px 1fr; gap: 40px; align-items: stretch; }
  .profile-card, .welcome-card { width: 100%; display: flex; flex-direction: column; }

  /* Animaciones de entrada */
  @keyframes slideInLeft { 0% { opacity: 0; transform: translateX(-80px) rotateY(30deg); filter: blur(8px); } 100% { opacity: 1; transform: translateX(0) rotateY(0); filter: blur(0); } }
  @keyframes slideInRight { 0% { opacity: 0; transform: translateX(80px) rotateY(-30deg); filter: blur(8px); } 100% { opacity: 1; transform: translateX(0) rotateY(0); filter: blur(0); } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes scaleIn { from { opacity: 0; transform: scale(0.7); } to { opacity: 1; transform: scale(1); } }
  @keyframes borderFlow { 0% { background-position: 0% 50%; } 100% { background-position: 300% 50%; } }
  @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.3); } }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }

  .animate-card { animation: slideInLeft 0.6s cubic-bezier(0.34, 1.2, 0.64, 1) forwards; }
  .welcome-section .animate-card { animation: slideInRight 0.6s cubic-bezier(0.34, 1.2, 0.64, 1) 0.1s forwards; opacity: 0; animation-fill-mode: forwards; }
  .info-row { animation: fadeInUp 0.5s ease forwards; opacity: 0; }
  .feature-item { animation: scaleIn 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards; opacity: 0; }
  .feature-item:nth-child(1) { animation-delay: 0.3s; }
  .feature-item:nth-child(2) { animation-delay: 0.4s; }
  .feature-item:nth-child(3) { animation-delay: 0.5s; }

  /* Tarjeta de perfil */
  .profile-card { background: rgba(255,255,255,0.98); backdrop-filter: blur(10px); border-radius: 32px; border: 1px solid rgba(255,255,255,0.3); transition: all 0.4s cubic-bezier(0.34,1.2,0.64,1); box-shadow: 0 20px 32px rgba(0,0,0,0.1); position: relative; }
  .profile-card:hover { transform: translateY(-8px) scale(1.01); box-shadow: 0 30px 50px rgba(0,0,0,0.15); border-color: rgba(36,107,209,0.3); }
  .card-glow { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(124,142,248,0.05), rgba(36,107,209,0.08), rgba(124,142,248,0.05), transparent); background-size: 200% 100%; animation: shimmer 4s infinite; pointer-events: none; border-radius: 32px; }
  
  .profile-header { background: linear-gradient(135deg, var(--gray-light) 0%, rgba(248,249,252,0.8) 100%); padding: 36px; display: flex; align-items: center; gap: 28px; border-bottom: 1px solid var(--border); }
  .profile-avatar { position: relative; flex-shrink: 0; }
  .avatar-image { width: 96px; height: 96px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary); box-shadow: 0 12px 24px rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.34,1.2,0.64,1); }
  .profile-card:hover .avatar-image { transform: scale(1.05); box-shadow: 0 0 0 6px rgba(36,107,209,0.2); }
  .avatar-placeholder { width: 96px; height: 96px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--secondary)); display: flex; align-items: center; justify-content: center; color: white; transition: all 0.4s cubic-bezier(0.34,1.2,0.64,1); }
  .profile-card:hover .avatar-placeholder { transform: scale(1.05); box-shadow: 0 0 0 6px rgba(36,107,209,0.2); }
  .avatar-placeholder svg { width: 48px; height: 48px; }
  .avatar-ring { position: absolute; inset: -6px; border-radius: 50%; background: conic-gradient(from 0deg, var(--primary), var(--secondary), var(--accent), var(--primary)); opacity: 0; transition: opacity 0.3s; animation: rotateRing 4s linear infinite; pointer-events: none; }
  @keyframes rotateRing { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .profile-card:hover .avatar-ring { opacity: 1; }
  
  .profile-title h2 { margin: 0 0 6px; font-size: 28px; font-weight: 700; font-family: 'Poppins', sans-serif; color: var(--gray-dark); transition: all 0.3s; }
  .profile-card:hover .profile-title h2 { background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .profile-title p { margin: 0; font-size: 14px; color: var(--gray-medium); }
  
  .profile-info { padding: 28px 36px; display: flex; flex-direction: column; gap: 20px; flex: 1; }
  .info-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--border); transition: all 0.3s cubic-bezier(0.34,1.2,0.64,1); }
  .info-row:hover { padding-left: 16px; border-bottom-color: var(--primary); transform: translateX(6px); }
  .info-label { display: flex; align-items: center; gap: 12px; font-size: 13px; font-weight: 600; color: var(--gray-medium); text-transform: uppercase; }
  .info-label svg { width: 20px; height: 20px; color: var(--primary); transition: all 0.3s; }
  .info-row:hover .info-label svg { transform: scale(1.2) rotate(8deg); color: var(--secondary); }
  .info-value { font-size: 15px; font-weight: 500; color: var(--gray-dark); text-align: right; }
  .status-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 24px; font-size: 13px; font-weight: 600; background: rgba(2,144,14,0.12); color: var(--success); }
  .status-dot { width: 10px; height: 10px; border-radius: 50%; background: currentColor; animation: pulse 2s infinite; }
  
  .profile-footer { background: linear-gradient(135deg, var(--gray-light) 0%, rgba(248,249,252,0.8) 100%); padding: 20px 36px; border-top: 1px solid var(--border); margin-top: auto; }
  .access-info { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--gray-medium); }
  .access-info svg { width: 18px; height: 18px; color: var(--primary); transition: transform 0.3s; }
  .profile-card:hover .access-info svg { transform: translateX(5px); }

  /* Tarjeta de bienvenida */
  .welcome-card { background: linear-gradient(135deg, rgba(44,58,66,0.95) 0%, rgba(31,42,51,0.95) 100%); backdrop-filter: blur(10px); border-radius: 32px; padding: 48px; position: relative; overflow: hidden; box-shadow: 0 20px 32px rgba(0,0,0,0.1); transition: all 0.4s cubic-bezier(0.34,1.2,0.64,1); border: 1px solid rgba(255,255,255,0.1); }
  .welcome-card:hover { transform: translateY(-8px) scale(1.01); box-shadow: 0 30px 50px rgba(0,0,0,0.15); border-color: rgba(124,142,248,0.3); }
  .card-border-animation { position: absolute; inset: -2px; background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent), var(--success), var(--primary)); background-size: 300% 100%; border-radius: 34px; opacity: 0; transition: opacity 0.3s; animation: borderFlow 3s linear infinite; z-index: -1; }
  .welcome-card:hover .card-border-animation { opacity: 0.5; }
  .welcome-card::before { content: ''; position: absolute; top: -30%; right: -20%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(36,107,209,0.25) 0%, rgba(124,142,248,0.1) 70%); border-radius: 50%; animation: floatOrb 15s ease-in-out infinite; }
  .welcome-card::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(124,142,248,0.2) 0%, rgba(36,107,209,0.08) 70%); border-radius: 50%; animation: floatOrb 18s ease-in-out infinite reverse; }
  
  .welcome-content { position: relative; z-index: 1; height: 100%; display: flex; flex-direction: column; flex: 1; }
  .welcome-badge { margin-bottom: 28px; }
  .badge-text { background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); padding: 8px 20px; border-radius: 40px; font-size: 12px; font-weight: 600; font-family: 'Poppins', sans-serif; color: rgba(255,255,255,0.9); border: 1px solid rgba(255,255,255,0.2); transition: all 0.3s; }
  .welcome-card:hover .badge-text { background: rgba(255,255,255,0.18); border-color: rgba(124,142,248,0.6); transform: translateY(-2px); }
  .welcome-title { font-size: 48px; font-weight: 700; font-family: 'Poppins', sans-serif; color: white; margin: 0 0 24px; line-height: 1.2; transition: transform 0.3s; }
  .welcome-card:hover .welcome-title { transform: translateX(6px); }
  .user-name-highlight { background: linear-gradient(135deg, var(--secondary), var(--primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block; animation: float 3s ease-in-out infinite; }
  .welcome-description { font-size: 16px; color: rgba(255,255,255,0.7); line-height: 1.7; margin: 0 0 48px; transition: transform 0.3s; flex: 1; }
  .welcome-card:hover .welcome-description { transform: translateX(6px); }
  .welcome-features { display: flex; gap: 24px; flex-wrap: wrap; margin-top: auto; }
  .feature-item { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.08); padding: 12px 24px; border-radius: 48px; backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.15); transition: all 0.3s cubic-bezier(0.34,1.2,0.64,1); }
  .feature-item:hover { background: rgba(255,255,255,0.15); transform: translateY(-6px) scale(1.03); border-color: rgba(124,142,248,0.8); }
  .feature-icon svg { width: 22px; height: 22px; color: var(--secondary); transition: all 0.3s; }
  .feature-item:hover .feature-icon svg { transform: scale(1.2) rotate(8deg); color: var(--accent); }
  .feature-item span { font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.85); font-family: 'Poppins', sans-serif; }

  /* Responsive */
  @media (max-width: 1024px) { .dashboard-container { grid-template-columns: 380px 1fr; gap: 28px; padding: 32px 24px; } .welcome-title { font-size: 40px; } .welcome-card { padding: 36px; } }
  @media (max-width: 768px) { .dashboard-container { grid-template-columns: 1fr; gap: 32px; padding: 24px 20px; } .profile-header { padding: 28px; flex-direction: column; text-align: center; } .profile-info { padding: 24px 28px; } .info-row { flex-direction: column; align-items: flex-start; text-align: left; } .info-value { text-align: left; } .profile-footer { padding: 18px 28px; } .welcome-title { font-size: 32px; } .welcome-description { font-size: 15px; margin-bottom: 32px; } .welcome-features { gap: 16px; } .feature-item { padding: 10px 20px; } }
  @media (max-width: 480px) { .dashboard-container { padding: 20px 16px; } .profile-header { padding: 24px; } .avatar-image, .avatar-placeholder { width: 80px; height: 80px; } .profile-title h2 { font-size: 24px; } .profile-info { padding: 20px 24px; } .welcome-card { padding: 24px; } .welcome-title { font-size: 28px; } .welcome-features { flex-direction: column; gap: 12px; } .feature-item { justify-content: center; } }
</style>