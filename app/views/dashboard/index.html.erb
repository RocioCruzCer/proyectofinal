<style>
  /* --- ESTILOS DEL DASHBOARD --- */
  :root {
    --primary-blue: #1A6D8F;
    --dark-grey: #2C3A42;
    --corporate-green: #2C6E4F;
    --accent-gold: #D9B650;
    --bg-light: #F5F7F9;
    --border: #E2E6EA;
    --text-main: #2C3A42;
    --text-sub: #6F7B85;
  }

  .dashboard-wrapper {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
    font-family: 'Segoe UI', Tahoma, sans-serif;
  }

  /* Encabezado */
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 20px;
  }

  .welcome-text h1 {
    color: var(--dark-grey);
    margin: 0;
    font-size: 28px;
    font-weight: 700;
  }

  .welcome-text p {
    color: var(--text-sub);
    margin: 5px 0 0;
    font-size: 16px;
  }

  .status-badge {
    background: #E8F0F2;
    color: var(--primary-blue);
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(26, 109, 143, 0.2);
  }

  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary-blue); }
  .pulse { animation: pulse-animation 2s infinite; }

  @keyframes pulse-animation {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(26, 109, 143, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(26, 109, 143, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(26, 109, 143, 0); }
  }

  .divider { border: none; border-top: 1px solid var(--border); margin-bottom: 40px; }

  /* Grid de Tarjetas */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .module-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid var(--border);
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .module-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 20px rgba(0,0,0,0.05);
    border-color: var(--primary-blue);
  }

  .card-icon {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
  }

  .card-icon svg { width: 30px; height: 30px; fill: white; }

  .module-card h3 {
    margin: 0 0 10px;
    color: var(--dark-grey);
    font-size: 18px;
    font-weight: 700;
  }

  .module-card p {
    color: var(--text-sub);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 25px;
    flex-grow: 1;
  }

  /* Botones de Módulo */
  .btn-module {
    text-decoration: none;
    background-color: transparent;
    border: 1px solid var(--primary-blue);
    color: var(--primary-blue);
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    transition: all 0.3s;
  }

  .btn-module:hover {
    background-color: var(--primary-blue);
    color: white;
  }
</style>