<div class="principal-wrapper">
  
  <!-- Cabecera -->
  <div class="principal-header">
    <h1>Módulo Principal 2.2</h1>
    <p>Gestión de registros del módulo principal</p>
  </div>

  <!-- Botón Nuevo Registro -->
  <% if puede_agregar?('principal1_1') %>
    <div class="action-bar">
      <button id="btnNuevo" class="btn-new">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Nuevo Registro
      </button>
    </div>
  <% end %>

  <!-- Tabla de registros -->
  <div class="table-container">
    <table class="principal-table" id="tabla-principal">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Estatus</th>
          <th>Acciones</th>
        </thead>
      <tbody id="tabla-cuerpo">
        <% @datos.each do |fila| %>
          <tr data-id="<%= fila[:id] %>">
            <td><strong><%= fila[:nombre] %></strong></td>
            <td>
              <% if fila[:estatus] == "Activo" %>
                <span class="badge-active">● Activo</span>
              <% elsif fila[:estatus] == "Inactivo" %>
                <span class="badge-inactive">● Inactivo</span>
              <% else %>
                <span class="badge-other"><%= fila[:estatus] %></span>
              <% end %>
            </td>
            <td class="actions-cell">
              <% if puede_editar?('principal1_1') %>
                <button onclick="editarRegistro(this, '<%= fila[:nombre] %>', '<%= fila[:estatus] %>')" class="btn-action btn-edit">Editar</button>
              <% end %>
              <% if puede_eliminar?('principal1_1') %>
                <button onclick="eliminarRegistro(this)" class="btn-action btn-delete">Eliminar</button>
              <% end %>
              <% unless puede_editar?('principal1_1') || puede_eliminar?('principal1_1') %>
                <span class="no-actions">Sin acciones</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Contador de registros -->
  <div class="counter-container">
    <span class="counter-label">Total de registros:</span>
    <span class="counter-value" id="contador-registros"><%= @datos.count %></span>
  </div>
</div>

<!-- Modal flotante para el formulario -->
<div id="modalRegistro" class="modal-overlay">
  <div class="modal-container">
    <div class="modal-card">
      <div class="modal-header">
        <h3 id="formTitulo">Crear Nuevo Registro</h3>
        <button id="btnCerrarModal" class="modal-close" title="Cerrar">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      
      <div class="modal-body">
        <div class="form-group">
          <label for="registroNombre">Nombre</label>
          <input type="text" id="registroNombre" class="form-input" placeholder="Ingrese el nombre del registro" required autocomplete="off">
          <span class="input-hint">Nombre descriptivo para el registro</span>
        </div>
        
        <div class="form-group">
          <label for="registroEstatus">Estatus</label>
          <select id="registroEstatus" class="form-select">
            <option value="Activo">Activo</option>
            <option value="Inactivo">Inactivo</option>
            <option value="Pendiente">Pendiente</option>
            <option value="En Proceso">En Proceso</option>
          </select>
          <span class="input-hint">Seleccione el estado actual del registro</span>
        </div>
      </div>
      
      <div class="modal-footer">
        <button id="btnGuardar" class="btn-primary">Guardar Registro</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Variables de color */
  :root {
    --primary: #246BD1;
    --primary-dark: #1A4F9C;
    --secondary: #7C8EF8;
    --accent: #F3B0B8;
    --success: #02900E;
    --success-light: #95BFA1;
    --warning: #FFC107;
    --gray-bg: #C2C7CC;
    --gray-light: #F8F9FC;
    --gray-medium: #6C757D;
    --gray-dark: #2C3E50;
    --white: #FFFFFF;
    --border: #E9ECEF;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.12);
    --shadow-modal: 0 25px 50px rgba(0, 0, 0, 0.25);
  }

  /* Tipografías */
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

  .principal-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px;
    font-family: 'Montserrat', sans-serif;
  }

  /* Cabecera */
  .principal-header {
    margin-bottom: 32px;
  }

  .principal-header h1 {
    font-size: 28px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
    margin: 0 0 8px 0;
  }

  .principal-header p {
    font-size: 14px;
    color: var(--gray-medium);
    margin: 0;
  }

  /* Action Bar */
  .action-bar {
    margin-bottom: 24px;
  }

  .btn-new {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
  }

  .btn-new:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  /* Tabla */
  .table-container {
    background: var(--white);
    border-radius: 20px;
    border: 1px solid var(--border);
    overflow-x: auto;
    margin-bottom: 20px;
  }

  .principal-table {
    width: 100%;
    border-collapse: collapse;
  }

  .principal-table thead {
    background: linear-gradient(135deg, var(--gray-dark) 0%, #1F2A33 100%);
  }

  .principal-table th {
    padding: 16px 20px;
    text-align: left;
    color: white;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
  }

  .principal-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--gray-dark);
    vertical-align: middle;
  }

  .principal-table tbody tr:hover {
    background: var(--gray-light);
  }

  .principal-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Badges de estatus */
  .badge-active {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(2, 144, 14, 0.12);
    color: var(--success);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge-inactive {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(108, 117, 125, 0.12);
    color: var(--gray-medium);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge-other {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(124, 142, 248, 0.12);
    color: var(--secondary);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  /* Botones de acción */
  .actions-cell {
    white-space: nowrap;
  }

  .btn-action {
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    margin-right: 8px;
  }

  .btn-edit {
    background: rgba(124, 142, 248, 0.1);
    color: var(--secondary);
  }

  .btn-edit:hover {
    background: var(--secondary);
    color: white;
    transform: translateY(-1px);
  }

  .btn-delete {
    background: rgba(243, 176, 184, 0.1);
    color: var(--accent);
  }

  .btn-delete:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-1px);
  }

  .no-actions {
    color: var(--gray-medium);
    font-size: 12px;
  }

  /* Contador */
  .counter-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--gray-light);
    border-radius: 12px;
    font-size: 13px;
  }

  .counter-label {
    color: var(--gray-medium);
    font-weight: 500;
  }

  .counter-value {
    color: var(--primary);
    font-weight: 700;
    font-size: 18px;
    font-family: 'Poppins', sans-serif;
  }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      backdrop-filter: blur(0);
    }
    to {
      opacity: 1;
      backdrop-filter: blur(8px);
    }
  }

  .modal-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: modalSlideUp 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  @keyframes modalSlideUp {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .modal-card {
    background: var(--white);
    border-radius: 32px;
    width: 500px;
    max-width: 90vw;
    overflow: hidden;
    box-shadow: var(--shadow-modal);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-sizing: border-box;
  }

  .modal-header {
    background: linear-gradient(135deg, var(--gray-light) 0%, #FFFFFF 100%);
    padding: 24px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }

  .modal-header h3 {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
  }

  .modal-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: var(--gray-medium);
  }

  .modal-close:hover {
    background: var(--gray-light);
    color: var(--primary);
    transform: rotate(90deg);
  }

  .modal-body {
    padding: 28px;
  }

  .form-group {
    margin-bottom: 24px;
    width: 100%;
    box-sizing: border-box;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-dark);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-input, .form-select {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    transition: all 0.2s;
    background: var(--gray-light);
    box-sizing: border-box;
  }

  .form-input:focus, .form-select:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--white);
    box-shadow: 0 0 0 3px rgba(36, 107, 209, 0.08);
  }

  .input-hint {
    display: block;
    font-size: 11px;
    color: var(--gray-medium);
    margin-top: 6px;
  }

  .modal-footer {
    padding: 20px 28px 28px;
    border-top: 1px solid var(--border);
    background: var(--gray-light);
    width: 100%;
    box-sizing: border-box;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    display: block;
    text-align: center;
    box-sizing: border-box;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(36, 107, 209, 0.3);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .principal-wrapper {
      padding: 20px;
    }

    .principal-table th,
    .principal-table td {
      padding: 12px 12px;
      font-size: 13px;
    }

    .btn-action {
      padding: 4px 10px;
      font-size: 11px;
      margin-right: 4px;
    }

    .modal-card {
      width: 95vw;
    }

    .modal-header {
      padding: 20px 24px;
    }

    .modal-header h3 {
      font-size: 20px;
    }

    .modal-body {
      padding: 24px;
    }

    .modal-footer {
      padding: 20px 24px 24px;
    }

    .counter-container {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .principal-wrapper {
      padding: 16px;
    }

    .principal-header h1 {
      font-size: 24px;
    }

    .btn-new {
      width: 100%;
      justify-content: center;
    }

    .modal-header {
      padding: 16px 20px;
    }

    .modal-header h3 {
      font-size: 18px;
    }

    .modal-body {
      padding: 20px;
    }

    .btn-primary {
      padding: 12px 20px;
      font-size: 14px;
    }

    .actions-cell {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .btn-action {
      margin-right: 0;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const modal = document.getElementById("modalRegistro");
    const btnNuevo = document.getElementById("btnNuevo");
    const btnCerrarModal = document.getElementById("btnCerrarModal");
    const btnGuardar = document.getElementById("btnGuardar");
    const inputNombre = document.getElementById("registroNombre");
    const inputEstatus = document.getElementById("registroEstatus");
    const tituloForm = document.getElementById("formTitulo");
    const tbody = document.querySelector("#tabla-principal tbody");
    const contadorSpan = document.getElementById("contador-registros");

    let modoEdicion = false;
    let filaEditando = null;

    function actualizarContador() {
      if (contadorSpan) {
        const filas = tbody ? tbody.querySelectorAll("tr") : [];
        contadorSpan.textContent = filas.length;
      }
    }

    function abrirModal() {
      if (modal) {
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
      }
    }

    function cerrarModal() {
      if (modal) {
        modal.style.display = "none";
        document.body.style.overflow = "";
      }
      modoEdicion = false;
      filaEditando = null;
      if (inputNombre) inputNombre.value = "";
      if (inputEstatus) inputEstatus.value = "Activo";
    }

    // Abrir modal para nuevo registro
    if (btnNuevo) {
      btnNuevo.addEventListener("click", () => {
        if (tituloForm) tituloForm.innerText = "Crear Nuevo Registro";
        modoEdicion = false;
        if (inputNombre) inputNombre.value = "";
        if (inputEstatus) inputEstatus.value = "Activo";
        abrirModal();
      });
    }

    // Cerrar modal
    if (btnCerrarModal) {
      btnCerrarModal.addEventListener("click", cerrarModal);
    }

    if (modal) {
      modal.addEventListener("click", function(e) {
        if (e.target === modal) cerrarModal();
      });
    }

    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && modal && modal.style.display === "flex") cerrarModal();
    });

    // Guardar registro
    if (btnGuardar) {
      btnGuardar.addEventListener("click", () => {
        const nombre = inputNombre ? inputNombre.value.trim() : "";
        if (!nombre) {
          alert("Por favor, ingrese un nombre para el registro");
          return;
        }

        const estatus = inputEstatus ? inputEstatus.value : "Activo";
        const puedeEditar = <%= puede_editar?('principal1_1') ? 'true' : 'false' %>;
        const puedeEliminar = <%= puede_eliminar?('principal1_1') ? 'true' : 'false' %>;

        if (modoEdicion && filaEditando) {
          // Editar registro existente
          const celdas = filaEditando.cells;
          if (celdas[0]) celdas[0].innerHTML = `<strong>${escapeHtml(nombre)}</strong>`;
          
          // Actualizar badge de estatus
          if (celdas[1]) {
            if (estatus === "Activo") {
              celdas[1].innerHTML = '<span class="badge-active">● Activo</span>';
            } else if (estatus === "Inactivo") {
              celdas[1].innerHTML = '<span class="badge-inactive">● Inactivo</span>';
            } else {
              celdas[1].innerHTML = `<span class="badge-other">${escapeHtml(estatus)}</span>`;
            }
          }
          cerrarModal();
        } else {
          // Crear nuevo registro
          let botonesHtml = "";
          if (puedeEditar) {
            botonesHtml += `<button onclick="editarRegistro(this, '${escapeHtml(nombre)}', '${escapeHtml(estatus)}')" class="btn-action btn-edit">Editar</button>`;
          }
          if (puedeEliminar) {
            botonesHtml += `<button onclick="eliminarRegistro(this)" class="btn-action btn-delete">Eliminar</button>`;
          }
          if (!puedeEditar && !puedeEliminar) {
            botonesHtml += `<span class="no-actions">Sin acciones</span>`;
          }

          let estatusHtml = "";
          if (estatus === "Activo") {
            estatusHtml = '<span class="badge-active">● Activo</span>';
          } else if (estatus === "Inactivo") {
            estatusHtml = '<span class="badge-inactive">● Inactivo</span>';
          } else {
            estatusHtml = `<span class="badge-other">${escapeHtml(estatus)}</span>`;
          }

          const nuevaFila = document.createElement("tr");
          nuevaFila.innerHTML = `
            <td><strong>${escapeHtml(nombre)}</strong></td>
            <td>${estatusHtml}</td>
            <td class="actions-cell">${botonesHtml}</td>
          `;
          
          if (tbody) tbody.appendChild(nuevaFila);
          actualizarContador();
          cerrarModal();
        }
      });
    }

    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Funciones globales para editar y eliminar
    window.editarRegistro = function(btn, nombre, estatus) {
      const fila = btn.closest("tr");
      if (tituloForm) tituloForm.innerText = "Editar Registro";
      modoEdicion = true;
      filaEditando = fila;
      if (inputNombre) inputNombre.value = nombre;
      if (inputEstatus) inputEstatus.value = estatus;
      abrirModal();
    };

    window.eliminarRegistro = function(btn) {
      if (confirm("¿Estás seguro de eliminar este registro? Esta acción no se puede deshacer.")) {
        const fila = btn.closest("tr");
        if (fila) fila.remove();
        actualizarContador();
      }
    };

    actualizarContador();
  });
</script>