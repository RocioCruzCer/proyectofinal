<!DOCTYPE html>
<html>
  <head>
    <title>Mi Sistema Web</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      /* ... (Mantenemos tus estilos CSS iguales, están excelentes) ... */
      :root {
        --primary-blue: #1A6D8F;
        --dark-bg: #2C3A42;
        --accent-gold: #D9B650;
        --success-green: #2C6E4F;
        --light-bg: #F5F7F9;
        --white: #FFFFFF;
        --border: #E2E6EA;
      }
      /* (Tus estilos de navbar y dropdown que ya tienes) */
    </style>
  </head>

  <body>
    <% if usuario_logueado? %>
      <nav class="navbar">
        <ul class="nav-menu">
          <li class="nav-item">
            <%= link_to dashboard_path, class: "nav-link" do %><strong>INICIO</strong><% end %>
          </li>

          <% # SECCIÓN SEGURIDAD %>
          <% if tiene_permiso?("seguridad") %>
            <li class="nav-item">
              <span class="nav-link">SEGURIDAD <small>▾</small></span>
              <ul class="dropdown">
                <% if tiene_permiso?("perfil") %><li><%= link_to "Perfil", perfiles_path %></li><% end %>
                <% if tiene_permiso?("modulo") %><li><%= link_to "Módulo", modulos_path %></li><% end %>
                <% if tiene_permiso?("permisosperfil") %><li><%= link_to "Permisos - Perfil", permisos_path %></li><% end %>
                <% if tiene_permiso?("usuario") %><li><%= link_to "Usuario", usuarios_path %></li><% end %>
              </ul>
            </li>
          <% end %>

          <% # SECCIÓN PRINCIPAL 1 %>
          <% if tiene_permiso?("principal1") %>
            <li class="nav-item">
              <span class="nav-link">PRINCIPAL 1 <small>▾</small></span>
              <ul class="dropdown">
                <% if tiene_permiso?("principal1_1") %><li><a href="#">Principal 1.1</a></li><% end %>
                <% if tiene_permiso?("principal1_2") %><li><a href="#">Principal 1.2</a></li><% end %>
              </ul>
            </li>
          <% end %>

          <% # SECCIÓN PRINCIPAL 2 (Añadida para completar tu diseño) %>
          <% if tiene_permiso?("principal2") %>
            <li class="nav-item">
              <span class="nav-link">PRINCIPAL 2 <small>▾</small></span>
              <ul class="dropdown">
                <% if tiene_permiso?("principal2_1") %><li><a href="#">Principal 2.1</a></li><% end %>
                <% if tiene_permiso?("principal2_2") %><li><a href="#">Principal 2.2</a></li><% end %>
              </ul>
            </li>
          <% end %>

          <% # SECCIÓN MÓDULOS EXTRAS (Dinámicos) %>
          <li class="nav-item">
            <span class="nav-link">MÓDULOS <small>▾</small></span>
            <ul class="dropdown">
              <% # Lista de módulos que ya tienen sección propia para no repetirlos %>
              <% excluidos = ['seguridad', 'perfil', 'modulo', 'permisosperfil', 'usuario', 'principal1', 'principal1_1', 'principal1_2', 'principal2', 'principal2_1', 'principal2_2'] %>
              <% Modulo.where.not(strNombreModulo: excluidos).each do |m| %>
                <% if tiene_permiso?(m.strNombreModulo) %>
                  <li><%= link_to m.strNombreModulo.titleize, "#" %></li>
                <% end %>
              <% end %>
            </ul>
          </li>
        </ul>

        <div class="user-section">
          <span>Bienvenido, <span class="user-name"><%= usuario_actual.strNombreUsuario %></span></span>
          <%= button_to "Cerrar Sesión", logout_path, method: :delete, data: { turbo: false }, class: "btn-logout" %>
        </div>
      </nav>
    <% end %>

    <div class="flash-container">
      <% if flash[:notice] && !current_page?(login_path) %>
        <div class="flash-banner notice-banner"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-banner" style="background-color: #FFEBEE; color: #C62828; border-left-color: #D32F2F;"><%= flash[:alert] %></div>
      <% end %>
    </div>

    <main style="padding: 20px;">
      <%= yield %>
    </main>
  </body>
</html>