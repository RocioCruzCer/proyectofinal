<body>
    <% if usuario_logueado? %>
      <nav style="background-color: #f8f9fa; padding: 15px; border-bottom: 1px solid #ddd; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
        
        <div>
          <strong>Mi Sistema Web</strong> | 
          <%= link_to "Dashboard", root_path %>
        </div>

        <div style="display: flex; gap: 15px; align-items: center;">
          <span>Hola, <%= usuario_actual.strNombreUsuario %></span>
          
          <%= button_to "Cerrar Sesión", logout_path, method: :delete, data: { turbo: false }, style: "padding: 5px 10px; cursor: pointer;" %>
        </div>

      </nav>
    <% end %>

    <% if flash[:notice] && !current_page?(login_path) %>
      <div style="background-color: #d4edda; color: #155724; padding: 10px; margin-bottom: 15px;">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= yield %>
  </body>