<div style="font-family: sans-serif; padding: 20px;">
  <h2>Permisos Perfil</h2>
  
  <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ddd;">
    <label>Perfil:</label><br>
    <select id="selectPerfil" style="width: 100%; padding: 8px; margin-top: 5px; margin-bottom: 10px;">
      <option value="">Seleccione un perfil...</option>
      <% @perfiles.each do |p| %>
        <option value="<%= p.id %>"><%= p.strNombrePerfil %></option>
      <% end %>
    </select>
    <button id="btnBuscar" style="background-color: #007bff; color: white; border: none; padding: 8px 20px; cursor: pointer; border-radius: 4px;">Buscar</button>
  </div>

  <h3 id="tituloModulos" style="display:none; color: #333;">[Módulos Web]</h3>

  <div id="contenedorTabla" style="display:none;">
    <table border="1" width="100%" cellspacing="0" cellpadding="10" style="text-align: left; border-collapse: collapse; border: 1px solid #dee2e6;">
      <thead style="background-color: #3b5bdb; color: white;">
        <tr>
          <th width="30%">Módulo</th>
          <th style="text-align:center;">Agregar</th>
          <th style="text-align:center;">Editar</th>
          <th style="text-align:center;">Eliminar</th>
          <th style="text-align:center;">Consultar</th>
          <th style="text-align:center;">Detalle</th>
        </tr>
      </thead>
      <tbody id="cuerpoMatriz">
        </tbody>
    </table>

    <div style="margin-top: 20px;">
      <button id="btnGuardarMatriz" style="padding: 10px 25px; background-color: #3b5bdb; color: white; border: none; cursor: pointer; border-radius: 4px; font-weight: bold;">Guardar</button>
      <button id="btnCancelarMatriz" style="padding: 10px 25px; background-color: #6c757d; color: white; border: none; cursor: pointer; border-radius: 4px;">Cancelar</button>
    </div>
  </div>
</div>

<script>
document.addEventListener("turbo:load", function() {
  const selectPerfil = document.getElementById("selectPerfil");
  const btnBuscar = document.getElementById("btnBuscar");
  const cuerpoMatriz = document.getElementById("cuerpoMatriz");
  const contenedor = document.getElementById("contenedorTabla");
  const titulo = document.getElementById("tituloModulos");
  const btnGuardarMatriz = document.getElementById("btnGuardarMatriz");
  
  const metaCsrf = document.querySelector('meta[name="csrf-token"]');
  if (!metaCsrf) return;
  const csrfToken = metaCsrf.content;

  // Acción de Buscar
  btnBuscar.onclick = () => {
    const perfilId = selectPerfil.value;
    if (!perfilId) {
      alert("Por favor, seleccione un perfil");
      return;
    }

    fetch(`/permisos/buscar.json?perfil_id=${perfilId}&nocache=${Date.now()}`)
      .then(res => res.json())
      .then(data => {
        cuerpoMatriz.innerHTML = "";
        
        // 🚨 EXTRAEMOS EL PERMISO PARA SABER SI BLOQUEAMOS LOS CHECKBOXES
        const canEdit = data.permisos_acciones.can_edit;
        const disabledAttr = canEdit ? "" : "disabled";

        // Si no puede editar, ocultamos el botón Guardar
        btnGuardarMatriz.style.display = canEdit ? "inline-block" : "none";
        
        // Iteramos sobre data.modulos_agrupados (la nueva estructura)
        for (const [tituloGrupo, modulos] of Object.entries(data.modulos_agrupados)) {
          
          if (modulos.length > 0) {
            const filaTitulo = document.createElement("tr");
            filaTitulo.style.backgroundColor = "#e9ecef";
            filaTitulo.innerHTML = `
              <td colspan="6" style="font-weight: bold; text-align: left; padding-left: 15px; border-bottom: 2px solid #ccc; text-transform: uppercase;">
                ${tituloGrupo}
              </td>
            `;
            cuerpoMatriz.appendChild(filaTitulo);
          }

          modulos.forEach(m => {
            const fila = document.createElement("tr");
            fila.setAttribute("data-id-modulo", m.idModulo);
            fila.classList.add("fila-modulo"); 
            
            // 🚨 APLICAMOS 'disabledAttr' A TODOS LOS CHECKBOXES SI NO TIENE PERMISO
            fila.innerHTML = `
              <td style="background: #fcfcfc; color: #555; border-bottom: 1px solid #eee; padding-left: 30px;">
                ${m.nombreModulo.charAt(0).toUpperCase() + m.nombreModulo.slice(1)}
              </td>
              <td align="center" style="border-bottom: 1px solid #eee;"><input type="checkbox" class="chk-agregar" ${m.bitAgregar ? 'checked' : ''} ${disabledAttr}></td>
              <td align="center" style="border-bottom: 1px solid #eee;"><input type="checkbox" class="chk-editar" ${m.bitEditar ? 'checked' : ''} ${disabledAttr}></td>
              <td align="center" style="border-bottom: 1px solid #eee;"><input type="checkbox" class="chk-eliminar" ${m.bitEliminar ? 'checked' : ''} ${disabledAttr}></td>
              <td align="center" style="border-bottom: 1px solid #eee;"><input type="checkbox" class="chk-consultar" ${m.bitConsulta ? 'checked' : ''} ${disabledAttr}></td>
              <td align="center" style="border-bottom: 1px solid #eee;"><input type="checkbox" class="chk-detalle" ${m.bitDetalle ? 'checked' : ''} ${disabledAttr}></td>
            `;
            cuerpoMatriz.appendChild(fila);
          });
        }

        contenedor.style.display = "block";
        titulo.style.display = "block";
      })
      .catch(error => alert("Error al cargar matriz. Posible falta de permisos."));
  };

  // Acción de Guardar Todo
  btnGuardarMatriz.onclick = () => {
    const filas = cuerpoMatriz.querySelectorAll("tr.fila-modulo");
    
    const listaPermisos = Array.from(filas).map(tr => {
      return {
        idModulo: tr.getAttribute("data-id-modulo"),
        bitAgregar: tr.querySelector(".chk-agregar").checked,
        bitEditar: tr.querySelector(".chk-editar").checked,
        bitEliminar: tr.querySelector(".chk-eliminar").checked,
        bitConsulta: tr.querySelector(".chk-consultar").checked,
        bitDetalle: tr.querySelector(".chk-detalle").checked
      };
    });

    const payload = {
      idPerfil: selectPerfil.value,
      permisos: listaPermisos
    };

    fetch("/permisos/guardar_matriz", {
      method: "POST",
      headers: { 
        "Content-Type": "application/json", 
        "X-CSRF-Token": csrfToken 
      },
      body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        alert("¡Permisos guardados con éxito!");
      } else {
        alert("Error al guardar: " + data.errors.join(", "));
      }
    });
  };

  document.getElementById("btnCancelarMatriz").onclick = () => {
    contenedor.style.display = "none";
    titulo.style.display = "none";
    selectPerfil.value = "";
  };
});
</script>