<div class="permisos-wrapper">
  
  <div class="permisos-header">
    <h1>Gestión de Permisos por Perfil</h1>
    <p>Configure los permisos de acceso para cada perfil del sistema</p>
  </div>

  <div class="selector-card">
    <div class="selector-content">
      <label for="selectPerfil">Seleccionar Perfil</label>
      <div class="selector-input-group">
        <select id="selectPerfil" class="form-select">
          <option value="" data-admin="false">Seleccione un perfil...</option>
          <% @perfiles.each do |p| %>
            <option value="<%= p.id %>" data-admin="<%= p.bitAdministrador ? 'true' : 'false' %>">
              <%= p.strNombrePerfil %>
            </option>
          <% end %>
        </select>
        <button id="btnBuscar" class="btn-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          Buscar
        </button>
      </div>
    </div>
  </div>

  <div id="contenedorTabla" style="display:none;">
    <div class="table-header">
      <h3 id="tituloModulos">Permisos por Módulo</h3>
    </div>
    
    <div class="table-container">
      <table class="permisos-table">
        <thead>
          <tr>
            <th>Módulo</th>
            <th style="text-align:center;">Agregar</th>
            <th style="text-align:center;">Editar</th>
            <th style="text-align:center;">Eliminar</th>
            <th style="text-align:center;">Consultar</th>
          </tr>
        </thead>
        <tbody id="cuerpoMatriz">
        </tbody>
      </table>
    </div>

    <div class="actions-container">
      <button id="btnGuardarMatriz" class="btn-primary">Guardar Permisos</button>
      <button id="btnCancelarMatriz" class="btn-secondary">Cancelar</button>
    </div>
  </div>
</div>

<style>
  /* Variables de color */
  :root {
    --primary: #246BD1;
    --primary-dark: #1A4F9C;
    --secondary: #7C8EF8;
    --accent: #F3B0B8;
    --success: #02900E;
    --success-light: #95BFA1;
    --gray-bg: #C2C7CC;
    --gray-light: #F8F9FC;
    --gray-medium: #6C757D;
    --gray-dark: #2C3E50;
    --white: #FFFFFF;
    --border: #E9ECEF;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  /* Tipografías */
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

  .permisos-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px;
    font-family: 'Montserrat', sans-serif;
  }

  /* Cabecera */
  .permisos-header {
    margin-bottom: 32px;
  }

  .permisos-header h1 {
    font-size: 28px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
    margin: 0 0 8px 0;
  }

  .permisos-header p {
    font-size: 14px;
    color: var(--gray-medium);
    margin: 0;
  }

  /* Selector Card */
  .selector-card {
    background: linear-gradient(135deg, var(--gray-light) 0%, #FFFFFF 100%);
    border-radius: 20px;
    border: 1px solid var(--border);
    padding: 24px;
    margin-bottom: 32px;
    box-shadow: var(--shadow);
  }

  .selector-content {
    max-width: 500px;
  }

  .selector-content label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-dark);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .selector-input-group {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .form-select {
    flex: 1;
    padding: 12px 16px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    background: var(--white);
    transition: all 0.2s;
    cursor: pointer;
  }

  .form-select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(36, 107, 209, 0.08);
  }

  .btn-search {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .btn-search:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  /* Tabla de Permisos */
  .table-header {
    margin-bottom: 20px;
  }

  .table-header h3 {
    font-size: 18px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
    margin: 0;
  }

  .table-container {
    background: var(--white);
    border-radius: 20px;
    border: 1px solid var(--border);
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .permisos-table {
    width: 100%;
    border-collapse: collapse;
  }

  .permisos-table thead {
    background: linear-gradient(135deg, var(--gray-dark) 0%, #1F2A33 100%);
  }

  .permisos-table th {
    padding: 16px 20px;
    text-align: left;
    color: white;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
  }

  .permisos-table th[align="center"] {
    text-align: center;
  }

  .permisos-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--gray-dark);
  }

  .permisos-table tbody tr:hover {
    background: var(--gray-light);
  }

  .permisos-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Filas de título de grupo */
  .grupo-titulo-row {
    background: linear-gradient(135deg, var(--gray-light) 0%, #FFFFFF 100%);
  }

  .grupo-titulo-row td {
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--primary);
    padding: 12px 20px;
    border-bottom: 2px solid var(--border);
  }

  /* Checkboxes personalizados */
  .permisos-table td[align="center"] {
    text-align: center;
  }

  .permisos-table input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--primary);
  }

  .permisos-table input[type="checkbox"]:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  /* Acciones */
  .actions-container {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 12px 28px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(36, 107, 209, 0.3);
  }

  .btn-secondary {
    background: var(--gray-light);
    color: var(--gray-medium);
    border: 1px solid var(--border);
    padding: 12px 28px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: var(--border);
  }

  /* Mensaje vacío */
  .empty-row td {
    text-align: center;
    padding: 40px !important;
    color: var(--gray-medium);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .permisos-wrapper {
      padding: 20px;
    }

    .selector-input-group {
      flex-direction: column;
    }

    .btn-search {
      width: 100%;
      justify-content: center;
    }

    .permisos-table th,
    .permisos-table td {
      padding: 12px 12px;
      font-size: 13px;
    }

    .actions-container {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .permisos-wrapper {
      padding: 16px;
    }

    .permisos-header h1 {
      font-size: 24px;
    }

    .selector-card {
      padding: 20px;
    }

    .permisos-table th,
    .permisos-table td {
      padding: 10px 8px;
      font-size: 12px;
    }
  }
</style>

<script>
document.addEventListener("turbo:load", function() {
  const selectPerfil = document.getElementById("selectPerfil");
  const btnBuscar = document.getElementById("btnBuscar");
  const cuerpoMatriz = document.getElementById("cuerpoMatriz");
  const contenedor = document.getElementById("contenedorTabla");
  const titulo = document.getElementById("tituloModulos");
  const btnGuardarMatriz = document.getElementById("btnGuardarMatriz");
  
  const metaCsrf = document.querySelector('meta[name="csrf-token"]');
  if (!metaCsrf) return;
  const csrfToken = metaCsrf.content;

  // Acción de Buscar
  btnBuscar.onclick = () => {
    const perfilId = selectPerfil.value;
    if (!perfilId) {
      alert("Por favor, seleccione un perfil");
      return;
    }

    // LEER SI EL PERFIL ES ADMINISTRADOR
    const opcionSeleccionada = selectPerfil.options[selectPerfil.selectedIndex];
    const esAdmin = opcionSeleccionada.getAttribute("data-admin") === "true";

    fetch(`/permisos/buscar.json?perfil_id=${perfilId}&nocache=${Date.now()}`)
      .then(res => res.json())
      .then(data => {
        cuerpoMatriz.innerHTML = "";
        
        const canEdit = data.permisos_acciones.can_edit;
        
        // BLOQUEAR CHECKBOXES: Si es Admin, o si no tiene permisos de edición, se bloquean.
        const disabledAttr = (esAdmin || !canEdit) ? "disabled" : "";
        
        // OCULTAR BOTÓN GUARDAR: Si es admin no necesita guardar
        btnGuardarMatriz.style.display = (!esAdmin && canEdit) ? "inline-flex" : "none";
        
        // Iterar sobre módulos agrupados
        for (const [tituloGrupo, modulos] of Object.entries(data.modulos_agrupados)) {
          
          if (modulos.length > 0) {
            const filaTitulo = document.createElement("tr");
            filaTitulo.className = "grupo-titulo-row";
            filaTitulo.innerHTML = `
              <td colspan="5" style="font-weight: bold; padding-left: 20px;">
                ${tituloGrupo}
              </td>
            `;
            cuerpoMatriz.appendChild(filaTitulo);
          }

          modulos.forEach(m => {
            const fila = document.createElement("tr");
            fila.setAttribute("data-id-modulo", m.idModulo);
            fila.classList.add("fila-modulo");
            
            // MARCAR CHECKBOXES: Si es admin siempre se marcan, si no, respeta la BD
            const chkAgregar = (esAdmin || m.bitAgregar) ? 'checked' : '';
            const chkEditar = (esAdmin || m.bitEditar) ? 'checked' : '';
            const chkEliminar = (esAdmin || m.bitEliminar) ? 'checked' : '';
            const chkConsultar = (esAdmin || m.bitConsulta) ? 'checked' : '';

            fila.innerHTML = `
              <td style="padding-left: 35px;">
                <strong>${m.nombreModulo.charAt(0).toUpperCase() + m.nombreModulo.slice(1)}</strong>
              </td>
              <td align="center">
                <input type="checkbox" class="chk-agregar" ${chkAgregar} ${disabledAttr}>
              </td>
              <td align="center">
                <input type="checkbox" class="chk-editar" ${chkEditar} ${disabledAttr}>
              </td>
              <td align="center">
                <input type="checkbox" class="chk-eliminar" ${chkEliminar} ${disabledAttr}>
              </td>
              <td align="center">
                <input type="checkbox" class="chk-consultar" ${chkConsultar} ${disabledAttr}>
              </td>
            `;
            cuerpoMatriz.appendChild(fila);
          });
        }

        contenedor.style.display = "block";
        titulo.style.display = "block";
      })
      .catch(error => {
        console.error("Error:", error);
        alert("Error al cargar la matriz de permisos");
      });
  };

  // Acción de Guardar Todo
  btnGuardarMatriz.onclick = () => {
    const filas = cuerpoMatriz.querySelectorAll("tr.fila-modulo");
    
    const listaPermisos = Array.from(filas).map(tr => {
      return {
        idModulo: tr.getAttribute("data-id-modulo"),
        bitAgregar: tr.querySelector(".chk-agregar").checked,
        bitEditar: tr.querySelector(".chk-editar").checked,
        bitEliminar: tr.querySelector(".chk-eliminar").checked,
        bitConsulta: tr.querySelector(".chk-consultar").checked
      };
    });

    const payload = {
      idPerfil: selectPerfil.value,
      permisos: listaPermisos
    };

    fetch("/permisos/guardar_matriz", {
      method: "POST",
      headers: { 
        "Content-Type": "application/json", 
        "X-CSRF-Token": csrfToken 
      },
      body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        alert("¡Permisos guardados con éxito!");
      } else {
        alert("Error al guardar: " + (data.errors ? data.errors.join(", ") : "Error desconocido"));
      }
    })
    .catch(error => {
      console.error("Error:", error);
      alert("Error al guardar los permisos");
    });
  };

  // Cancelar
  document.getElementById("btnCancelarMatriz").onclick = () => {
    contenedor.style.display = "none";
    titulo.style.display = "none";
    selectPerfil.value = "";
  };
});
</script>