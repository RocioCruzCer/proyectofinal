<div class="perfiles-wrapper">
  
  <div class="perfiles-header">
    <h1>Gestión de Perfiles</h1>
    <p>Administra los roles y niveles de acceso del sistema</p>
  </div>

  <% if puede_agregar?("perfil") %>
    <div class="action-bar">
      <button id="btnNuevo" class="btn-new">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Nuevo Perfil
      </button>
    </div>
  <% end %>

  <div class="table-container">
    <table class="perfiles-table">
      <thead>
        <tr>
          <th>Nombre del Perfil</th>
          <th>Administrador</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaPerfilesCuerpo">
      </tbody>
    </table>
  </div>

  <div class="pagination-container">
    <button id="btnPrimero" class="pagination-btn" title="Primera página">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M11 17L6 12l5-5M18 17l-5-5 5-5"/>
      </svg>
    </button>
    <button id="btnAnterior" class="pagination-btn" title="Página anterior">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
      Anterior
    </button>
    <span id="textoPaginacion" class="pagination-info">Página 1</span>
    <button id="btnSiguiente" class="pagination-btn" title="Página siguiente">
      Siguiente
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
    <button id="btnUltimo" class="pagination-btn" title="Última página">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M13 17l5-5-5-5M6 17l5-5-5-5"/>
      </svg>
    </button>
  </div>
</div>

<div id="modalPerfil" class="modal-overlay">
  <div class="modal-container">
    <div class="modal-card">
      <div class="modal-header">
        <h3 id="formTitulo">Crear Nuevo Perfil</h3>
        <button id="btnCerrarModal" class="modal-close" title="Cerrar">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      
      <div class="modal-body">
        <input type="hidden" id="perfilId">
        
        <div class="form-group">
          <label for="strNombrePerfil">Nombre del Perfil</label>
          <input type="text" id="strNombrePerfil" class="form-input" placeholder="Ej: Administrador" required autocomplete="off" maxlength="15">
          <span class="input-hint">Máximo 15 caracteres, sin espacios.</span>
        </div>
        
        <div class="form-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" id="bitAdministrador">
            <span class="checkbox-custom"></span>
            <span>Es Administrador</span>
          </label>
          <p class="checkbox-hint">Los administradores tienen acceso total al sistema, incluyendo todas las funcionalidades y configuraciones.</p>
        </div>
      </div>
      
      <div class="modal-footer">
        <button id="btnGuardar" class="btn-primary">Guardar Perfil</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Variables de color */
  :root {
    --primary: #246BD1;
    --primary-dark: #1A4F9C;
    --secondary: #7C8EF8;
    --accent: #F3B0B8;
    --success: #02900E;
    --success-light: #95BFA1;
    --gray-bg: #C2C7CC;
    --gray-light: #F8F9FC;
    --gray-medium: #6C757D;
    --gray-dark: #2C3E50;
    --white: #FFFFFF;
    --border: #E9ECEF;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.12);
    --shadow-modal: 0 25px 50px rgba(0, 0, 0, 0.25);
  }

  /* Tipografías */
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

  .perfiles-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px;
    font-family: 'Montserrat', sans-serif;
  }

  /* Cabecera */
  .perfiles-header {
    margin-bottom: 32px;
  }

  .perfiles-header h1 {
    font-size: 28px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
    margin: 0 0 8px 0;
  }

  .perfiles-header p {
    font-size: 14px;
    color: var(--gray-medium);
    margin: 0;
  }

  /* Action Bar */
  .action-bar {
    margin-bottom: 24px;
  }

  .btn-new {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
  }

  .btn-new:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  /* Tabla */
  .table-container {
    background: var(--white);
    border-radius: 20px;
    border: 1px solid var(--border);
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .perfiles-table {
    width: 100%;
    border-collapse: collapse;
  }

  .perfiles-table thead {
    background: linear-gradient(135deg, var(--gray-dark) 0%, #1F2A33 100%);
  }

  .perfiles-table th {
    padding: 16px 20px;
    text-align: left;
    color: white;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
  }

  .perfiles-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--gray-dark);
  }

  .perfiles-table tbody tr:hover {
    background: var(--gray-light);
  }

  .perfiles-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Badges */
  .badge-admin {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(36, 107, 209, 0.1);
    color: var(--primary);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge-user {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--gray-light);
    color: var(--gray-medium);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }

  /* Botones de acción */
  .btn-action {
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    margin-right: 8px;
  }

  .btn-edit {
    background: rgba(124, 142, 248, 0.1);
    color: var(--secondary);
  }

  .btn-edit:hover {
    background: var(--secondary);
    color: white;
    transform: translateY(-1px);
  }

  .btn-delete {
    background: rgba(243, 176, 184, 0.1);
    color: var(--accent);
  }

  .btn-delete:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-1px);
  }

  .no-actions {
    color: var(--gray-medium);
    font-size: 12px;
  }

  /* Paginación */
  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-dark);
    cursor: pointer;
    transition: all 0.2s;
  }

  .pagination-btn:hover:not(:disabled) {
    background: var(--gray-light);
    border-color: var(--primary);
    color: var(--primary);
  }

  .pagination-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination-info {
    font-size: 14px;
    font-weight: 500;
    color: var(--gray-dark);
    padding: 0 8px;
  }

  /* Mensaje vacío */
  .empty-row td {
    text-align: center;
    padding: 40px !important;
    color: var(--gray-medium);
  }

  /* ============================================
     MODAL FLOTANTE
  ============================================ */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      backdrop-filter: blur(0);
    }
    to {
      opacity: 1;
      backdrop-filter: blur(8px);
    }
  }

  .modal-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: modalSlideUp 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  @keyframes modalSlideUp {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .modal-card {
    background: var(--white);
    border-radius: 32px;
    width: 600px;
    max-width: 90vw;
    overflow: hidden;
    box-shadow: var(--shadow-modal);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-sizing: border-box;
  }

  .modal-header {
    background: linear-gradient(135deg, var(--gray-light) 0%, #FFFFFF 100%);
    padding: 28px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }

  .modal-header h3 {
    margin: 0;
    font-size: 24px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    color: var(--gray-dark);
  }

  .modal-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: var(--gray-medium);
  }

  .modal-close:hover {
    background: var(--gray-light);
    color: var(--primary);
    transform: rotate(90deg);
  }

  .modal-body {
    padding: 32px;
  }

  .form-group {
    margin-bottom: 28px;
    width: 100%;
    box-sizing: border-box;
  }

  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-dark);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-input {
    width: 100%;
    padding: 14px 18px;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    font-size: 15px;
    font-family: 'Montserrat', sans-serif;
    transition: all 0.2s;
    background: var(--gray-light);
    box-sizing: border-box;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--white);
    box-shadow: 0 0 0 4px rgba(36, 107, 209, 0.08);
  }

  .input-hint {
    display: block;
    font-size: 12px;
    color: var(--gray-medium);
    margin-top: 8px;
  }

  .checkbox-group {
    margin-bottom: 0;
  }

  .checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    position: relative;
  }

  .checkbox-label input {
    display: none;
  }

  .checkbox-custom {
    width: 22px;
    height: 22px;
    border: 2px solid var(--border);
    border-radius: 7px;
    display: inline-block;
    position: relative;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .checkbox-label input:checked + .checkbox-custom {
    background: var(--primary);
    border-color: var(--primary);
  }

  .checkbox-label input:checked + .checkbox-custom::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 13px;
  }

  .checkbox-label span:last-child {
    font-size: 15px;
    font-weight: 500;
    color: var(--gray-dark);
  }

  .checkbox-hint {
    font-size: 13px;
    color: var(--gray-medium);
    margin: 10px 0 0 34px;
    line-height: 1.5;
  }

  .modal-footer {
    padding: 24px 32px 32px;
    border-top: 1px solid var(--border);
    background: var(--gray-light);
    width: 100%;
    box-sizing: border-box;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 14px 28px;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    display: block;
    text-align: center;
    box-sizing: border-box;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(36, 107, 209, 0.3);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .perfiles-wrapper {
      padding: 20px;
    }

    .perfiles-table th,
    .perfiles-table td {
      padding: 12px 16px;
    }

    .btn-action {
      padding: 4px 10px;
      font-size: 11px;
    }

    .modal-card {
      width: 90vw;
    }

    .modal-header {
      padding: 22px 24px;
    }

    .modal-header h3 {
      font-size: 20px;
    }

    .modal-body {
      padding: 24px;
    }

    .modal-footer {
      padding: 20px 24px 24px;
    }

    .form-input {
      padding: 12px 16px;
      font-size: 14px;
    }

    .pagination-container {
      gap: 8px;
    }

    .pagination-btn {
      padding: 6px 12px;
    }
  }

  @media (max-width: 480px) {
    .perfiles-wrapper {
      padding: 16px;
    }

    .perfiles-header h1 {
      font-size: 24px;
    }

    .btn-new {
      width: 100%;
      justify-content: center;
    }

    .modal-header {
      padding: 18px 20px;
    }

    .modal-header h3 {
      font-size: 18px;
    }

    .modal-body {
      padding: 20px;
    }

    .form-group label {
      font-size: 13px;
    }

    .form-input {
      padding: 12px 14px;
      font-size: 14px;
    }

    .checkbox-label span:last-child {
      font-size: 14px;
    }

    .checkbox-hint {
      font-size: 12px;
    }

    .btn-primary {
      padding: 12px 24px;
      font-size: 14px;
    }

    .pagination-container {
      gap: 6px;
    }

    .pagination-btn {
      padding: 6px 10px;
      font-size: 12px;
    }

    .pagination-btn svg {
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  document.addEventListener("turbo:load", function() {
    let paginaActual = 1;
    let totalPaginas = 1;
    const metaCsrf = document.querySelector('meta[name="csrf-token"]');
    if (!metaCsrf) return;
    const csrfToken = metaCsrf.content;

    const cuerpoTabla = document.getElementById("tablaPerfilesCuerpo");
    const modal = document.getElementById("modalPerfil");
    const inputId = document.getElementById("perfilId");
    const inputNombre = document.getElementById("strNombrePerfil");
    const inputAdmin = document.getElementById("bitAdministrador");
    const tituloForm = document.getElementById("formTitulo");
    const btnNuevo = document.getElementById("btnNuevo");
    const btnCerrarModal = document.getElementById("btnCerrarModal");
    const btnPrimero = document.getElementById("btnPrimero");
    const btnUltimo = document.getElementById("btnUltimo");

    function cargarPerfiles(pagina) {
      fetch(`/perfiles.json?page=${pagina}&nocache=${Date.now()}`)
        .then(response => response.json())
        .then(data => {
          cuerpoTabla.innerHTML = "";
          totalPaginas = data.total_paginas;
          
          if(data.perfiles.length === 0) {
            cuerpoTabla.innerHTML = `<tr class="empty-row"><td colspan="3">No hay perfiles registrados</td></tr>`;
          }

          const permisoEditar = data.permisos.editar;
          const permisoEliminar = data.permisos.eliminar;

          data.perfiles.forEach(perfil => {
            let botonesHtml = "";
            
            if (permisoEditar) {
              botonesHtml += `<button onclick="editarPerfil(${perfil.id}, '${perfil.strNombrePerfil}', ${perfil.bitAdministrador})" class="btn-action btn-edit">Editar</button>`;
            }
            
            if (permisoEliminar) {
              botonesHtml += `<button onclick="eliminarPerfil(${perfil.id})" class="btn-action btn-delete">Eliminar</button>`;
            }

            if (botonesHtml === "") {
              botonesHtml = "<span class='no-actions'>Sin acciones</span>";
            }

            const adminBadge = perfil.bitAdministrador 
              ? '<span class="badge-admin">👑 Administrador</span>' 
              : '<span class="badge-user">👤 Usuario</span>';

            const fila = document.createElement("tr");
            fila.innerHTML = `
              <td><strong>${escapeHtml(perfil.strNombrePerfil)}</strong></td>
              <td>${adminBadge}</td>
              <td>${botonesHtml}</td>
            `;
            cuerpoTabla.appendChild(fila);
          });

          document.getElementById("textoPaginacion").innerText = `Página ${data.pagina_actual} de ${data.total_paginas}`;
          document.getElementById("btnAnterior").disabled = data.pagina_actual <= 1;
          document.getElementById("btnSiguiente").disabled = data.pagina_actual >= data.total_paginas;
          document.getElementById("btnPrimero").disabled = data.pagina_actual <= 1;
          document.getElementById("btnUltimo").disabled = data.pagina_actual >= data.total_paginas;
          paginaActual = data.pagina_actual;
        })
        .catch(error => console.error("Error:", error));
    }

    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function abrirModal() {
      modal.style.display = "flex";
      document.body.style.overflow = "hidden";
    }

    function cerrarModal() {
      modal.style.display = "none";
      document.body.style.overflow = "";
    }

    cargarPerfiles(paginaActual);

    // Eventos de paginación
    document.getElementById("btnPrimero").addEventListener("click", () => {
      if (paginaActual > 1) cargarPerfiles(1);
    });
    document.getElementById("btnAnterior").addEventListener("click", () => {
      if (paginaActual > 1) cargarPerfiles(paginaActual - 1);
    });
    document.getElementById("btnSiguiente").addEventListener("click", () => {
      if (paginaActual < totalPaginas) cargarPerfiles(paginaActual + 1);
    });
    document.getElementById("btnUltimo").addEventListener("click", () => {
      if (paginaActual < totalPaginas) cargarPerfiles(totalPaginas);
    });

    // Abrir modal al hacer clic en Nuevo Perfil
    if (btnNuevo) {
      btnNuevo.addEventListener("click", () => {
        tituloForm.innerText = "Crear Nuevo Perfil";
        inputId.value = "";
        inputNombre.value = "";
        inputAdmin.checked = false;
        abrirModal();
      });
    }

    // Cerrar modal con la X
    if (btnCerrarModal) {
      btnCerrarModal.addEventListener("click", cerrarModal);
    }

    // Cerrar modal al hacer clic fuera
    modal.addEventListener("click", function(e) {
      if (e.target === modal) {
        cerrarModal();
      }
    });

    // Cerrar modal con tecla Escape
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && modal.style.display === "flex") {
        cerrarModal();
      }
    });

    // Validar en tiempo real: eliminar espacios mientras escribe
    inputNombre.addEventListener("input", function() {
      this.value = this.value.replace(/\s/g, ''); // Borra cualquier espacio al instante
    });

    // Guardar perfil
    document.getElementById("btnGuardar").addEventListener("click", () => {
      const nombre = inputNombre.value.trim();
      
      // Validaciones antes de enviar
      if (nombre === "") {
        alert("El nombre del perfil es obligatorio");
        return;
      }
      
      if (nombre.length > 15) {
        alert("El nombre del perfil no puede tener más de 15 letras");
        return;
      }
      
      if (/\s/.test(nombre)) {
        alert("El nombre del perfil no puede contener espacios");
        return;
      }

      const id = inputId.value;
      const metodo = id ? "PUT" : "POST";
      const url = id ? `/perfiles/${id}.json` : "/perfiles.json";
      
      const payload = {
        perfil: {
          strNombrePerfil: nombre,
          bitAdministrador: inputAdmin.checked
        }
      };

      fetch(url, {
        method: metodo,
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": csrfToken
        },
        body: JSON.stringify(payload)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          cerrarModal();
          cargarPerfiles(paginaActual);
        } else {
          alert("Error: " + (data.errors ? data.errors.join(", ") : "Error al guardar"));
        }
      })
      .catch(error => console.error("Error:", error));
    });

    window.editarPerfil = function(id, nombre, isAdmin) {
      tituloForm.innerText = "Editar Perfil";
      inputId.value = id;
      inputNombre.value = nombre;
      inputAdmin.checked = isAdmin === true || isAdmin === "true";
      abrirModal();
    };

    window.eliminarPerfil = function(id) {
      if (confirm("¿Estás seguro de eliminar este perfil? Esta acción no se puede deshacer.")) {
        fetch(`/perfiles/${id}.json`, {
          method: "DELETE",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            cargarPerfiles(paginaActual);
          } else {
            alert("Error al eliminar el perfil");
          }
        })
        .catch(error => console.error("Error:", error));
      }
    };
  });
</script>